# QuickBooks API Configuration
QB_CLIENT_ID=YOUR_CLIENT_ID_HERE
QB_CLIENT_SECRET=YOUR_CLIENT_SECRET_HERE
QB_REDIRECT_URI=YOUR_REDIRECT_URI_HERE
QB_ENVIRONMENT=sandbox

# Local Database Cache Settings
DATABASE_URL=YOUR_DATABASE_URL_HERE
DB_ENGINE=mssql
DB_SERVER=YOUR_SERVER_NAME_HERE
DB_NAME=YOUR_DATABASE_NAME_HERE

# --- NEW: Cloud LLM Engine Key ---
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Azure SQL Database Credentials
AZURE_DB_SERVER=YOUR_AZURE_SERVER_NAME_HERE.database.windows.net
AZURE_DB_NAME=YOUR_DATABASE_NAME_HERE
AZURE_DB_USER=YOUR_AZURE_DB_USERNAME_HERE
AZURE_DB_PASSWORD=YOUR_AZURE_DB_PASSWORD_HERE